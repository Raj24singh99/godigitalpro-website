{
  "hosting": {
    "public": "dist",
    "ignore": ["**/.*", "**/node_modules/**"],
    "cleanUrls": true,
    "trailingSlash": false,

    "headers": [
      {
        "source": "**/*.@(js|css)",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
        ]
      },
      {
        "source": "**/*.@(png|jpg|jpeg|gif|svg|webp|ico)",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
        ]
      },
      {
        "source": "**/*.html",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=300, s-maxage=300, stale-while-revalidate=86400" }
        ]
      },
      {
        "source": "/favicon.ico",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=86400" }
        ]
      },
      {
        "source": "/favicon.svg",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=86400" }
        ]
      },
      {
        "source": "/apple-touch-icon.png",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=86400" }
        ]
      },
      {
        "source": "/site.webmanifest",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=86400" }
        ]
      },
      {
        "source": "/robots.txt",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=86400" }
        ]
      },
      {
        "source": "/sitemap.xml",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=86400" }
        ]
      }
    ],

    "redirects": [
      { "source": "/about", "destination": "/about_us", "type": 301 },
      { "source": "/blogs", "destination": "/blog", "type": 301 },
      { "source": "/app", "destination": "/", "type": 301 },
      { "source": "/learn", "destination": "/", "type": 301 },
      { "source": "/learn/**", "destination": "/", "type": 301 },
      { "source": "/digital-products/**", "destination": "/", "type": 301 },
      { "source": "/tools", "destination": "/", "type": 301 },
      { "source": "/tools/**", "destination": "/", "type": 301 },
      { "source": "/locations/**", "destination": "/", "type": 301 },
      { "source": "/services/marketplaces", "destination": "/services/video-ad-production", "type": 301 },
      { "source": "/industries/d2c-ecommerce", "destination": "/", "type": 301 },
      { "source": "/industries/saas-startups", "destination": "/", "type": 301 },
      { "source": "/industries/healthcare", "destination": "/", "type": 301 },
      { "source": "/industries/local-services", "destination": "/", "type": 301 },
      { "source": "/industries/b2b-services", "destination": "/", "type": 301 },
      { "source": "/digital-marketing-agency-near-me", "destination": "/", "type": 301 },
      { "source": "/best-digital-marketing-agency", "destination": "/", "type": 301 },
      { "source": "/best-google-ads-agency", "destination": "/", "type": 301 },
      { "source": "/best-digital-marketing-agency-for-startups", "destination": "/", "type": 301 }
    ],

    "rewrites": [
      { "source": "/sitemap.xml", "destination": "/sitemap.xml" },
      { "source": "/robots.txt", "destination": "/robots.txt" },
      { "source": "**", "destination": "/index.html" }
    ]
  }
}
